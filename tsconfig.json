{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "@tsconfig/node22",
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": "src",
		"types": ["node"],
		"allowImportingTsExtensions": true,
		"rewriteRelativeImportExtensions": true,
		"verbatimModuleSyntax": true,
		"sourceMap": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/**/*.test.ts"]
}
